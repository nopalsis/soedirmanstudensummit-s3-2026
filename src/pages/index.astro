---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/HeroSections/HeroSection.astro';
import Divider from '../components/divider/Divider.astro';
import KnowMore from '../components/KnowMore/KnowMore.astro';
import Logo from '../components/Logo/Logo.astro';
import Sambutan from '../components/sambutan/Sambutan.astro';
import Marque from '../components/Marque.astro';
---

<Layout title="Selamat Datang">
  <Hero />
    <div class="relative z-20 -mb-12 sm:-mb-24 md:-mb-32">
      <Divider class="-mt-4 md:-mt-16" />
     </div>
  <KnowMore />
  <Logo />
  <Sambutan />
  <Marque 
      bgColor="bg-dark-base"
      textColor="text-white-base"
      direction="right"
      img="/images/logo-parts/logo.webp"
    />
</Layout>
