---
import Layout from '../../layouts/Layout.astro';
import paguyubanData from '../../data/paguyuban';
---

<Layout title="Paguyuban - Soedirman Student Summit 2026">
	<main class="min-h-screen pt-24 pb-20 bg-gradient-to-b from-[#1E4B82] to-[#0F1F52]">
		<div class="max-w-screen-xl mx-auto px-4 sm:px-6 md:px-8">
			<!-- Header -->
			<div class="text-center mb-16">
				<h1 class="text-4xl md:text-5xl lg:text-6xl font-reikna font-bold text-white mb-4">
					Paguyuban Mahasiswa
				</h1>
				<p class="text-s3-gold text-lg md:text-xl max-w-2xl mx-auto">
					Organisasi kedaerahan yang menyatukan mahasiswa berdasarkan asal daerah dan budaya lokal
				</p>
			</div>

			<!-- Grid Paguyuban -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{paguyubanData.map((org) => (
					<div
						class="group relative overflow-hidden rounded-xl border border-s3-gold/20 bg-gradient-to-br from-s3-blue/40 to-s3-deep-blue/40 backdrop-blur-sm p-6 transition-all duration-300 hover:border-s3-gold hover:shadow-[0_0_30px_rgba(235,197,85,0.3)] hover:scale-105 cursor-pointer"
					>
						<div class="absolute inset-0 bg-gradient-to-br from-s3-gold/0 to-s3-gold/0 group-hover:from-s3-gold/10 group-hover:to-s3-gold/5 transition-all duration-300" />
						
						<div class="relative z-10 flex flex-col h-full">
							<!-- Logo -->
							<div class="mb-4 h-20 w-20">
								<img
									src={org.image}
									alt={org.name}
									class="h-full w-full object-contain"
								/>
							</div>

							<!-- Content -->
							<h2 class="text-xl font-bold text-white mb-2 group-hover:text-s3-gold transition-colors line-clamp-2">
								{org.name}
							</h2>
							<p class="text-sm text-gray-300 mb-4 line-clamp-3">
								{org.description}
							</p>

							<!-- Location Badge -->
							<div class="mt-auto">
								<span class="inline-block px-3 py-1 text-xs font-medium text-s3-gold bg-s3-gold/10 border border-s3-gold/20 rounded-full">
									{org.location}
								</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</main>
</Layout>

<style>
	main {
		background-attachment: fixed;
	}
</style>
