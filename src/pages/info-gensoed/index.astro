---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen flex flex-col items-center justify-center pt-24 px-6 bg-[--color-dark-base]">
		<h1 class="text-4xl md:text-5xl font-space-grotesk font-bold text-center text-[--color-text-primary] mb-6">
			Halaman <span class="text-gradient capitalize">info-gensoed/index</span>
		</h1>
		<p class="text-[--color-text-secondary] font-plus-jakarta-sans text-center max-w-xl">
			Halaman ini sudah terhubung dengan rute dan navigasi, namun kontennya masih dalam tahap pengembangan.
		</p>
	</main>
</Layout>
