---
---

<footer class="w-full bg-gradient-to-r from-s3-blue to-s3-blue text-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 md:px-8 py-12 md:py-16">
    <!-- Top Section: Logo, Title, Description -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-12 md:mb-16">
      <!-- Brand Section -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <img
            src="/images/logo.webp"
            alt="Soedirman Student Summit Logo"
            width="64"
            height="64"
            class="w-16 h-16 object-contain shrink-0"
          />
          <div class="flex flex-col">
            <h3 class="text-sm md:text-base font-plus-jakarta-sans font-bold text-white">
              Soedirman Student Summit
            </h3>
            <p class="text-xs md:text-sm font-plus-jakarta-sans font-light text-white/80">
              Universitas Jenderal Soedirman
            </p>
          </div>
        </div>
        <p class="text-sm md:text-base text-white/90 leading-relaxed font-plus-jakarta-sans">
          Soedirman Student Summit (S3) adalah acara tahunan Unsoed untuk menyambut mahasiswa baru dan memperkenalkan kehidupan kampus.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-base md:text-lg font-plus-jakarta-sans font-semibold text-s3-gold mb-4">
          Tautan Cepat
        </h4>
        <ul class="flex flex-col gap-2 font-plus-jakarta-sans text-sm md:text-base">
          <li>
            <a href="/" class="text-white/80 hover:text-s3-gold transition-colors duration-200">
              Beranda
            </a>
          </li>
          <li>
            <a href="/tentang-unsoed" class="text-white/80 hover:text-s3-gold transition-colors duration-200">
              Tentang Unsoed
            </a>
          </li>
          <li>
            <a href="/info-gensoed" class="text-white/80 hover:text-s3-gold transition-colors duration-200">
              Gensoed Guide
            </a>
          </li>
          <li>
            <a href="/committee" class="text-white/80 hover:text-s3-gold transition-colors duration-200">
              Committee
            </a>
          </li>
          <li>
            <a href="/hubungi-kami" class="text-white/80 hover:text-s3-gold transition-colors duration-200">
              Hubungi Kami
            </a>
          </li>
        </ul>
      </div>

      <!-- Address & Contact -->
      <div>
        <h4 class="text-base md:text-lg font-plus-jakarta-sans font-semibold text-s3-gold mb-4">
          Kontak & Lokasi
        </h4>
        <div class="space-y-4">
          <div class="font-plus-jakarta-sans text-sm md:text-base">
            <p class="text-white/80 leading-relaxed">
              Jl. Profesor DR. HR Boenyamin No.708, Dukuhbandong, Grendeng, Kec. Purwokerto Utara, Kabupaten Banyumas, Jawa Tengah 53122
            </p>
          </div>
          <a href="mailto:contact@summit2026.unsoed.ac.id" class="text-white/80 hover:text-s3-gold transition-colors duration-200 font-plus-jakarta-sans text-sm md:text-base">
            soedirmanstudentsummit2026@gmail.com
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px bg-white/20 mb-8"></div>

