---
import NavLink from "./NavLink.astro";

const currentPath = Astro.url.pathname;
console.log("Current Path:", currentPath);
---

<header
  id="header"
  class="w-full flex justify-center items-center sticky top-0 z-[999] bg-gradient-to-r from-s3-blue to-s3-blue shadow-[0_4px_20px_rgba(0,0,0,0.35)] min-h-[var(--nav-height)]"
>
  <nav class="w-full max-w-screen-xl">
    <!-- Desktop Nav -->
    <div class="hidden lg:flex justify-between items-center w-full px-8 py-1">
      <a href="/" class="flex items-center shrink-0 group">
         <img
           src="/images/logo.webp"
           alt="Soedirman Student Summit Logo"
           width="80"
           height="80"
           class="w-20 h-20 object-contain transition-all duration-300 group-hover:scale-110 group-hover:-rotate-6"
           id="logoDesktop"
         />
      </a>

       <div class="flex items-center justify-center gap-8 ml-18">
          <NavLink href="/" active={currentPath === "/" || currentPath === ""}>Beranda</NavLink>

          <div class="relative inline-block text-left">
            <div class="group">
              <button
                id="gensodDropdownButton"
                type="button"
                class="inline-flex justify-center items-center text-s3-gold/90 hover:text-s3-gold text-base font-plus-jakarta-sans font-medium transition-all duration-300 w-fit cursor-pointer relative h-6 flex items-center after:absolute after:bottom-[-4px] after:left-0 after:h-0.5 after:bg-s3-gold after:transition-all after:duration-300 after:w-0 hover:after:w-full"
              >
                Gensoed Guide
                <svg
                  class="w-4 h-4 ml-1 rotate-90 transition-all duration-200"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path fill-rule="evenodd" d="M10 12l-5-5h10l-5 5z"></path>
                </svg>
              </button>
              <div
                id="gensodDropdownMenu"
                class="absolute left-0 w-44 mt-2 origin-top-left bg-gradient-to-br from-white to-gray-50 divide-y divide-gray-200 rounded-2xl shadow-xl opacity-0 invisible transition duration-300 overflow-hidden backdrop-blur-sm"
              >
                <div class="py-2">
                   <a
                     href="/assignment"
                     class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                     >Assignment</a
                   >
                  <a
                    href="/info-gensoed"
                    class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                    >Starterpack</a
                  >
                  <a
                    href="/info-gensoed/twibbon"
                    class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                    >Twibbon</a
                  >
                </div>
              </div>
            </div>
          </div>

          <div class="relative inline-block text-left">
            <div class="group">
              <button
                id="dropdownButton"
                type="button"
                class="inline-flex justify-center items-center text-s3-gold/90 hover:text-s3-gold text-base font-plus-jakarta-sans font-medium transition-all duration-300 w-fit cursor-pointer relative h-6 flex items-center after:absolute after:bottom-[-4px] after:left-0 after:h-0.5 after:bg-s3-gold after:transition-all after:duration-300 after:w-0 hover:after:w-full"
              >
                Jelajahi Unsoed
                <svg
                  class="w-4 h-4 ml-1 rotate-90 transition-all duration-200"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path fill-rule="evenodd" d="M10 12l-5-5h10l-5 5z"></path>
                </svg>
              </button>
              <div
                id="dropdownMenu"
                class="absolute left-0 w-44 mt-2 origin-top-left bg-gradient-to-br from-white to-gray-50 divide-y divide-gray-200 rounded-2xl shadow-xl opacity-0 invisible transition duration-300 overflow-hidden backdrop-blur-sm"
              >
                <div class="py-2">
                  <a
                    href="/tentang-unsoed"
                    class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                    >Tentang Unsoed</a
                  >
                  <a
                    href="/ukm"
                    class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                    >UKM</a
                  >
                  <a
                    href="/paguyuban"
                    class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                    >Paguyuban</a
                  >
                </div>
              </div>
            </div>
          </div>

          <NavLink href="/committee" active={currentPath.startsWith("/committee")}>Committee</NavLink>
        </div>

       <a
         href="/hubungi-kami"
         class="bg-[#E7C055] text-s3-blue text-base font-plus-jakarta-sans font-bold px-6 py-2.5 rounded-full hover:shadow-lg hover:brightness-95 transition-all duration-300 shrink-0 hover:scale-105 hover:-translate-y-1"
       >
         Hubungi Kami
       </a>
    </div>

    <!-- Mobile Nav -->
    <div class="lg:hidden flex justify-between items-center px-5 py-3">
       <a href="/" class="flex items-center hover:opacity-80 transition-opacity group">
          <img
            src="/images/logo.webp"
            alt="Soedirman Student Summit Logo"
            width="38"
            height="38"
            class="w-9.5 h-9.5 object-contain transition-all duration-300 group-hover:scale-110 group-hover:-rotate-6"
          />
       </a>
      <button class="hamburger hamburger--collapse h-[21px]" type="button">
        <span class="hamburger-box">
          <span class="hamburger-inner"></span>
        </span>
      </button>

      <div class="fixed inset-0 pointer-events-none z-[9999]">
        <div
          class="fixed top-[var(--nav-height)] right-0 mt-0 w-[280px] rounded-3xl transition-transform duration-300 flex flex-col gap-4 px-6 py-6 items-end bg-gradient-to-b from-s3-blue to-s3-blue/95 shadow-[0_10px_30px_rgba(0,0,0,0.35)] translate-x-full pointer-events-auto z-[9999] overflow-hidden"
          id="sidebar"
        >
          <NavLink href="/" active={currentPath === "/"}>Beranda</NavLink>

           <div class="relative inline-block text-left w-full">
             <button
               id="mobileGensodDropdownButton"
               type="button"
               class="flex items-center text-s3-gold/90 hover:text-s3-gold text-base font-plus-jakarta-sans font-medium transition-all duration-300 w-full justify-end cursor-pointer relative h-6 after:absolute after:bottom-[-4px] after:right-0 after:h-0.5 after:bg-s3-gold after:transition-all after:duration-300 after:w-0 hover:after:w-full"
             >
               Gensoed Guide
               <svg
                 class="w-4 h-4 ml-1 rotate-90 transition-all duration-200"
                 xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 20 20"
                 fill="currentColor"
               >
                 <path fill-rule="evenodd" d="M10 12l-5-5h10l-5 5z"></path>
               </svg>
             </button>
             <div
               id="mobileGensodDropdownMenu"
               class="absolute right-0 w-44 mt-2 origin-top-right bg-gradient-to-br from-white to-gray-50 divide-y divide-gray-200 rounded-2xl shadow-xl opacity-0 invisible transition duration-300 overflow-hidden backdrop-blur-sm z-50"
             >
               <div class="py-2">
                 <a
                    href="/assignment"
                    class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                    >Assignment</a
                  >
                 <a
                   href="/info-gensoed"
                   class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                   >Starterpack</a
                 >
                 <a
                   href="/info-gensoed/twibbon"
                   class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                   >Twibbon</a
                 >
               </div>
             </div>
           </div>

           <div class="relative inline-block text-left w-full">
             <button
               type="button"
               id="toggleButton"
               class="flex items-center text-s3-gold/90 hover:text-s3-gold text-base font-plus-jakarta-sans font-medium transition-all duration-300 w-full justify-end cursor-pointer relative h-6 after:absolute after:bottom-[-4px] after:right-0 after:h-0.5 after:bg-s3-gold after:transition-all after:duration-300 after:w-0 hover:after:w-full"
             >
               Jelajahi Unsoed
               <svg
                 class="w-4 h-4 ml-1 rotate-90 transition-all duration-200"
                 xmlns="http://www.w3.org/2000/svg"
                 viewBox="0 0 20 20"
                 fill="currentColor"
               >
                 <path fill-rule="evenodd" d="M10 12l-5-5h10l-5 5z"></path>
               </svg>
             </button>
             <div
               id="contentArea"
               class="absolute right-0 w-44 mt-2 origin-top-right bg-gradient-to-br from-white to-gray-50 divide-y divide-gray-200 rounded-2xl shadow-xl opacity-0 invisible transition duration-300 overflow-hidden backdrop-blur-sm z-50"
             >
               <div class="py-2">
                 <a
                   href="/tentang-unsoed"
                   class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                   >Tentang Unsoed</a
                 >
                 <a
                   href="/ukm"
                   class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                   >UKM</a
                 >
                 <a
                   href="/paguyuban"
                   class="block px-4 py-3 text-s3-blue text-sm font-plus-jakarta-sans font-medium hover:bg-s3-gold/15 hover:text-s3-blue transition-all duration-200"
                   >Paguyuban</a
                 >
               </div>
             </div>
           </div>

           <NavLink href="/committee" active={currentPath.startsWith("/committee")}>Committee</NavLink>
           <a
             href="/hubungi-kami"
             class="bg-gradient-to-r from-s3-gold to-yellow-400 text-s3-blue text-sm font-plus-jakarta-sans font-bold px-6 py-2.5 rounded-full hover:shadow-lg hover:brightness-110 transition-all duration-300 w-full text-center hover:scale-105 hover:-translate-y-1"
           >
             Hubungi Kami
           </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  .hamburger {
    padding: 0px 0px;
    display: inline-block;
    cursor: pointer;
    transition-property: opacity, filter;
    transition-duration: 0.15s;
    transition-timing-function: linear;
    font: inherit;
    color: inherit;
    text-transform: none;
    background-color: transparent;
    border: 0;
    margin: 0;
    overflow: visible;
  }
  .hamburger:hover {
    opacity: 0.7;
  }
  .hamburger.is-active:hover {
    opacity: 0.7;
  }
  .hamburger.is-active .hamburger-inner,
  .hamburger.is-active .hamburger-inner::before,
  .hamburger.is-active .hamburger-inner::after {
    background-color: var(--color-s3-gold);
  }

  .hamburger-box {
    width: 21px;
    height: 16.5px;
    display: inline-block;
    position: relative;
  }

  .hamburger-inner {
    display: block;
    top: 50%;
    margin-top: -1.25px;
  }
  .hamburger-inner,
  .hamburger-inner::before,
  .hamburger-inner::after {
    width: 21px;
    height: 2.5px;
    background-color: var(--color-s3-gold);
    border-radius: 2.5px;
    position: absolute;
    transition-property: transform;
    transition-duration: 0.15s;
    transition-timing-function: ease;
  }
  .hamburger-inner::before,
  .hamburger-inner::after {
    content: "";
    display: block;
  }
  .hamburger-inner::before {
    top: -7px;
  }
  .hamburger-inner::after {
    bottom: -7px;
  }

  .hamburger--collapse .hamburger-inner {
    top: auto;
    bottom: 0;
    transition-duration: 0.13s;
    transition-delay: 0.13s;
    transition-timing-function: cubic-bezier(0.55, 0.055, 0.675, 0.19);
  }
  .hamburger--collapse .hamburger-inner::after {
    top: -14px;
    transition:
      top 0.2s 0.2s cubic-bezier(0.33333, 0.66667, 0.66667, 1),
      opacity 0.1s linear;
  }
  .hamburger--collapse .hamburger-inner::before {
    transition:
      top 0.12s 0.2s cubic-bezier(0.33333, 0.66667, 0.66667, 1),
      transform 0.13s cubic-bezier(0.55, 0.055, 0.675, 0.19);
  }
  .hamburger--collapse.is-active .hamburger-inner {
    transform: translate3d(0, -7px, 0) rotate(-45deg);
    transition-delay: 0.22s;
    transition-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);
  }
  .hamburger--collapse.is-active .hamburger-inner::after {
    top: 0;
    opacity: 0;
    transition:
      top 0.2s cubic-bezier(0.33333, 0, 0.66667, 0.33333),
      opacity 0.1s 0.22s linear;
  }
  .hamburger--collapse.is-active .hamburger-inner::before {
    top: 0;
    transform: rotate(-90deg);
    transition:
      top 0.1s 0.16s cubic-bezier(0.33333, 0, 0.66667, 0.33333),
      transform 0.13s 0.25s cubic-bezier(0.215, 0.61, 0.355, 1);
  }

  #header {
    transition: all 0.3s ease;
  }

  #header.scrolled {
    background: rgba(0, 40, 85, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }
</style>

<script>
  // Scroll detection untuk glass effect
  const header = document.getElementById("header");
  let lastScrollY = 0;

  window.addEventListener("scroll", () => {
    lastScrollY = window.scrollY;
    
    if (lastScrollY > 10) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  }, { passive: true });

  const hamburgerButton = document.querySelector(".hamburger");
  const sidebar = document.querySelector("#sidebar");
  
  // Ensure sidebar starts hidden
  if (sidebar) {
    sidebar.classList.add("translate-x-full");
  }
  
  if (hamburgerButton && sidebar) {
    hamburgerButton.addEventListener("click", () => {
      if (hamburgerButton.classList.contains("is-active")) {
        sidebar.classList.add("translate-x-full");
        hamburgerButton.classList.remove("is-active");
      } else {
        sidebar.classList.remove("translate-x-full");
        hamburgerButton.classList.add("is-active");
      }
    });
  }

  document.addEventListener("DOMContentLoaded", function () {
    const button = document.getElementById("dropdownButton") as HTMLButtonElement | null;
    const menu = document.getElementById("dropdownMenu") as HTMLElement | null;
    if (!button || !menu) return;
    const wrapper = button.closest(".group") as HTMLElement;
    if (!wrapper) return;
    const svgIcon = button.querySelector("svg") as SVGElement;

    wrapper.addEventListener("mouseenter", function () {
      menu.classList.remove("opacity-0", "invisible");
      menu.classList.add("opacity-100", "visible");
      svgIcon.style.transform = "rotate(0deg)";
    });

    wrapper.addEventListener("mouseleave", function () {
      menu.classList.remove("opacity-100", "visible");
      menu.classList.add("opacity-0", "invisible");
      svgIcon.style.transform = "rotate(90deg)";
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    const gensodButton = document.getElementById("gensodDropdownButton") as HTMLButtonElement | null;
    const gensodMenu = document.getElementById("gensodDropdownMenu") as HTMLElement | null;
    if (!gensodButton || !gensodMenu) return;
    const gensodWrapper = gensodButton.closest(".group") as HTMLElement;
    if (!gensodWrapper) return;
    const gensodSvgIcon = gensodButton.querySelector("svg") as SVGElement;

    gensodWrapper.addEventListener("mouseenter", function () {
      gensodMenu.classList.remove("opacity-0", "invisible");
      gensodMenu.classList.add("opacity-100", "visible");
      gensodSvgIcon.style.transform = "rotate(0deg)";
    });

    gensodWrapper.addEventListener("mouseleave", function () {
      gensodMenu.classList.remove("opacity-100", "visible");
      gensodMenu.classList.add("opacity-0", "invisible");
      gensodSvgIcon.style.transform = "rotate(90deg)";
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    const toggleButton = document.getElementById("toggleButton") as HTMLButtonElement | null;
    const contentArea = document.getElementById("contentArea") as HTMLElement | null;
    if (!toggleButton || !contentArea) return;
    const svgIcon = toggleButton.querySelector("svg") as SVGElement;

    toggleButton.addEventListener("click", function (event: MouseEvent) {
      const isVisible = contentArea.classList.contains("opacity-100");
      if (!isVisible) {
        contentArea.classList.remove("opacity-0", "invisible");
        contentArea.classList.add("opacity-100", "visible");
        svgIcon.style.transform = "rotate(0deg)";
      } else {
        contentArea.classList.remove("opacity-100", "visible");
        contentArea.classList.add("opacity-0", "invisible");
        svgIcon.style.transform = "rotate(90deg)";
      }
      event.stopPropagation();
    });

    document.addEventListener("click", function (event: MouseEvent) {
      if (
        event.target instanceof Node &&
        !contentArea.contains(event.target) &&
        !toggleButton.contains(event.target)
      ) {
        contentArea.classList.remove("opacity-100", "visible");
        contentArea.classList.add("opacity-0", "invisible");
      }
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    const mobileGensodButton = document.getElementById("mobileGensodDropdownButton") as HTMLButtonElement | null;
    const mobileGensodMenu = document.getElementById("mobileGensodDropdownMenu") as HTMLElement | null;
    if (!mobileGensodButton || !mobileGensodMenu) return;
    const mobileGensodSvgIcon = mobileGensodButton.querySelector("svg") as SVGElement;

    mobileGensodButton.addEventListener("click", function (event: MouseEvent) {
      const isVisible = mobileGensodMenu.classList.contains("opacity-100");
      if (!isVisible) {
        mobileGensodMenu.classList.remove("opacity-0", "invisible");
        mobileGensodMenu.classList.add("opacity-100", "visible");
        mobileGensodSvgIcon.style.transform = "rotate(0deg)";
      } else {
        mobileGensodMenu.classList.remove("opacity-100", "visible");
        mobileGensodMenu.classList.add("opacity-0", "invisible");
        mobileGensodSvgIcon.style.transform = "rotate(90deg)";
      }
      event.stopPropagation();
    });

    document.addEventListener("click", function (event: MouseEvent) {
      if (
        event.target instanceof Node &&
        !mobileGensodMenu.contains(event.target) &&
        !mobileGensodButton.contains(event.target)
      ) {
        mobileGensodMenu.classList.remove("opacity-100", "visible");
        mobileGensodMenu.classList.add("opacity-0", "invisible");
      }
    });
  });
</script>