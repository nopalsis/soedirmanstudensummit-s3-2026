    img: "/images/logo-parts/kepala.svg",
  },
  {
    title: "Lope",
    desc: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Neque porro quisquam est, qui dolorem ipsum quia dolor sit amet.",
    img: "/images/logo-parts/lope.svg",
  },
  {
    title: "Paruh",
    desc: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut labore et dolore magnam aliquam quaerat voluptatem animi.",
    img: "/images/logo-parts/paruh.svg",
  },
  {
    title: "S3",
    desc: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse.",
    img: "/images/logo-parts/s3.svg",
  },
  {
