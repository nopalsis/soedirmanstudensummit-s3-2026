---
import DocumentationCard from "./DocumentationCard.astro";
---

<section
  id="know-more"
  class="pb-24 md:pt-24 section-padding-x text-white-base bg-[#76A3ED] bg-[url('/images/elements/bgbatik.svg')] perbukitan-size bg-bottom bg-no-repeat m-auto overflow-x-hidden"
>
  <div class="container max-w-screen-xl mx-auto">

    <!-- Mascots Description (side by side, speech bubble menyatu di gambar) -->
    <div class="w-full mb-8 sm:mb-12 flex flex-col items-center justify-center gap-4">
  <div
    class="w-1/2 sm:max-w-[220px] md:max-w-[600px]"
    data-aos="fade-right"
    data-aos-duration="1000"
    data-aos-easing="ease-in-out"
    data-aos-offset="300"
    data-aos-once="true"
  >
    <img
      src="/images/mascots/maskot-cowo.svg"
      alt="Perkenalan Chibi Maskot S3 Cowok"
      class="w-full h-auto"
    />
  </div>

  <div
    class="w-1/2 sm:max-w-[220px] md:max-w-[600px]"
    data-aos="fade-left"
    data-aos-duration="1000"
    data-aos-easing="ease-in-out"
    data-aos-offset="300"
    data-aos-once="true"
  >
    <img
      src="/images/mascots/maskot-cewe.svg"
      alt="Perkenalan Chibi Maskot S3 Cewek"
      class="w-full h-auto"
    />
  </div>

  
  <div class="w-full flex justify-center mb-8">
      <div class="max-w-[220px] sm:max-w-xs md:max-w-sm" data-aos="fade-down" data-aos-duration="800" data-aos-delay="200" data-aos-easing="ease-in-out" data-aos-offset="300" data-aos-once="true">
        <img class="w-full h-auto" src="/images/mascots/chibi-maskot.svg" alt="Maskot Soedirman Student Summit" />
      </div>
</div>

    <!-- Mengenal Lebih Dekat dengan S3 -->
    <div class="w-full">
      <div class="max-w-screen-md mx-auto text-center mb-8">
        <h2 class="font-semibold capitalize header-font-size mb-4 font-heading p-2 text-dark-base backdrop-blur-sm bg-white-base bg-opacity-25 rounded-md" data-aos="fade-up" data-aos-duration="600" data-aos-easing="ease-in-out" data-aos-offset="200" data-aos-once="true">
          Mengenal Lebih Dekat dengan S3!!
        </h2>
        <p class="normal-font-size lg:text-xl text-justify md:text-center text-secondary p-2 md:p-2 text-dark-base backdrop-blur-sm bg-white-base bg-opacity-25 rounded-md" data-aos="fade-up" data-aos-duration="600" data-aos-delay="100" data-aos-easing="ease-in-out" data-aos-offset="50" data-aos-once="true">
          Soedirman Student Summit (S3) merupakan kegiatan tahunan yang diselenggarakan sebagai wadah untuk pengenalan kehidupan perkuliahan dan untuk menyambut mahasiswa baru Universitas Jenderal Soedirman. Rangkaian kegiatan S3 bertujuan sebagai gerbang awal mahasiswa baru untuk mengenal dirinya sendiri dengan mengimplementasikan nilai-nilai yang akan dibawakan, serta mengenal lebih jauh tentang Universitas Jenderal Soedirman
        </p>
      </div>
    </div>

    <!-- Documentation Photos -->
    <div class="w-full flex justify-center">
      <DocumentationCard />
    </div>
  </div>
</section>

<style>
  .perbukitan-size { background-size: 800px; }
  @media screen and (min-width: 768px) { .perbukitan-size { background-size: cover; } }
</style>