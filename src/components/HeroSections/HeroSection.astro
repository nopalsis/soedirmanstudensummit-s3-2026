---
// HeroSections — Soedirman Student Summit 2026
---

<section
  id="hero"
  class="relative w-full h-[calc(100vh-var(--nav-height))] flex justify-center items-center overflow-hidden bg-gradient-to-b from-[#1E4B82] to-[#0F1F52] px-6 "
>
  <img
    src="/images/elements/wave.svg"
    alt=""
    class="absolute top-0 left-0 w-full h-auto z-0 opacity-80"
  />


  <img
    src="/images/elements/burung.svg"
    alt=""
    class="absolute top-[12%] right-[17%] w-24 md:w-250 z-10 animate-bird-fly"
  />


  
  
  <img
  src="/images/elements/wayang-awan.svg"
  alt="Wayang"
  class="absolute left-0 bottom-5 z-999 w-40 sm:w-56 md:w-72 lg:w-80 animate-fade-in-left"
  />
  
  
  <img
  src="/images/elements/wayang-awan.svg"
  alt="wayang"
  class="absolute bottom-10 right-0 w-40 sm:w-56 md:w-72 lg:w-80 z-20 -scale-x-100 animate-fade-in-left"
  />
  
  <div class="absolute top-[10%] w-56 h-56 md:w-78 md:h-78 lg:w-80 lg:h-80 z-10 size-80 rounded-full bg-[radial-gradient(circle_at_center,#FFDC96_0%,#FFC34C_100%)] shadow-[0_0_47.2px_6px_rgba(253,200,92,1)]">
    
  </div>
  
  <article
    class="flex flex-col items-center gap-4 lg:gap-6 w-full max-w-3xl text-center z-30 relative animate-fade-up">
    <div class="flex flex-col gap-1 ">
      <h1
        class="text-s3-blue font-reikna text-3xl sm:text-4xl md:text-5xl lg:text-6xl drop-shadow-[0_2px_0_rgba(201,168,76,0.6)] leading-none"
      >
        Soedirman
      </h1>

      <h1 class="text-s3-blue font-reikna text-3xl sm:text-4xl md:text-5xl lg:text-6xl drop-shadow-[0_2px_0_rgba(201,168,76,0.6)] leading none">
        Student Summit
      </h1>

      <p class="text-s3-blue font-goblin text-4xl sm:text-5xl lg:text-7xl leading-none">
        2026
      </p>
    </div>
    <p class="text-white text-sm sm:text-base md:text-lg max-w-xl font-plus-jakarta-sans mt-15"
    >
      Selamat Datang Generasi Soedirman di Universitas Jenderal Soedirman
    </p>
  </article>

  <img
    src="/images/elements/ombakbawah.svg"
    alt=""
    class="absolute bottom-0 left-0 w-full h-auto z-[1]"
  />
</section>

<style>

  @keyframes birdFly {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(-12px, -10px);
    }
  }
  .animate-bird-fly {
    animation: birdFly 5s ease-in-out infinite;
  }

  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  .animate-fade-in-left {
    animation: fadeInLeft 900ms ease-out both;
  }
  .animate-fade-in-right {
    animation: fadeInRight 900ms ease-out both;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 700ms ease-out 300ms both;
  }
</style>