---
// HeroSections — Soedirman Student Summit 2026
---

<section
  id="hero"
  class="relative w-full h-[calc(100vh-var(--nav-height))] flex justify-center items-center overflow-hidden bg-gradient-to-b from-[#1E4B82] to-[#0F1F52] px-4 sm:px-6"
>
  <!-- Wave (hidden di mobile, tampil mulai sm) -->
<img
  src="/images/elements/wave.svg"
  alt=""
  class="hidden sm:block absolute top-0 left-0 w-full h-auto z-0 animate-wave-fade-in"
/>

<!-- Burung Kiri (terbang ke kanan) -->
<img
  src="/images/elements/burung2.svg"
  alt=""
  class="absolute left-[15%] xs:left-[20%] sm:left-[24%] top-[20%] xs:top-[20%] sm:top-[26%] w-7 xs:w-9 sm:w-14 md:w-20 z-10 animate-bird-fly-1"
/>


<!-- Burung Kanan (terbang ke kiri) -->
<img
  src="/images/elements/burung1.svg"
  alt=""
  class="absolute right-[12%] xs:right-[16%] sm:right-[20%] top-[20%] xs:top-[20%] sm:top-[18%] w-8 xs:w-11 sm:w-16 md:w-24 z-10 animate-bird-fly-1"
/>


<!-- Wayang kiri -->
<img
  src="/images/elements/wayang-awan.svg"
  alt="Wayang"
  class="absolute left-0 bottom-0 sm:bottom-5 z-20 w-35 xs:w-28 sm:w-48 md:w-72 lg:w-80 animate-fade-in-left-delayed"
/>

<!-- Wayang kanan (mirror) -->
<img
  src="/images/elements/wayang-awan.svg"
  alt="Wayang"
  class="absolute bottom-0 sm:bottom-10 right-0 w-35 xs:w-28 sm:w-48 md:w-72 lg:w-80 z-20 -scale-x-100 animate-fade-in-right-delayed"
/>

<div class="absolute top-1/2 -translate-y-1/2 sm:top-[10%] sm:translate-y-0 left-1/2 -translate-x-1/2 w-full px-4 z-10">
  <div class="flex flex-col items-center animate-fade-up-sun">

    <!-- Matahari -->
    <div class="relative w-44 h-44 xs:w-48 xs:h-48 sm:w-56 sm:h-56 md:w-72 md:h-72 lg:w-80 lg:h-80 shrink-0">
      <div
        class="absolute inset-0 rounded-full bg-[radial-gradient(circle_at_center,#FFDC96_0%,#FFC34C_100%)] shadow-[0_0_47.2px_6px_rgba(253,200,92,1)]">
      </div>

      <!-- Judul -->
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center justify-center gap-0 z-30 text-center w-[92vw] sm:w-[90vw] max-w-3xl px-2">

        <h1
          class="text-s3-blue font-reikna drop-shadow-[0_4px_0_rgba(0,0,0,0.3)] leading-none soedirman-hero">
          <span class="soedirman-text"><span class="stylistic-letter">S</span>oedirma<span class="stylistic-letter">n</span></span>
        </h1>

        <h1
          class="text-s3-blue font-reikna drop-shadow-[0_4px_0_rgba(0,0,0,0.3)] leading-none -mt-5 sm:-mt-6 md:-mt-7 lg:-mt-8 student-summit-hero">
          <span class="student-summit-text"><span class="stylistic-letter">S</span>tuden<span class="stylistic-letter">t</span> <span class="stylistic-letter">S</span>ummi<span class="stylistic-letter">t</span></span>
        </h1>

        <p
          class="text-s3-blue font-goblin text-xl xs:text-2xl sm:text-3xl md:text-4xl lg:text-5xl leading-none drop-shadow-[0_4px_0_rgba(0,0,0,0.3)] year-text">
          2026
        </p>

      </div>
    </div>

    <!-- Subtitle -->
    <p
      class="text-white text-xs xs:text-sm sm:text-base md:text-lg max-w-xl w-[92vw] sm:w-[90vw] font-plus-jakarta-sans text-center mt-8 sm:mt-12 md:mt-14 z-30 px-2">
      Nyalakan asa, Wujudkan Karya, Gelorakan Jiwa.
    </p>

  </div>
</div>

<!-- Ombak bawah -->
<img
  src="/images/elements/ombakbawah.svg"
  alt=""
  class="absolute bottom-0 left-0 w-full h-auto z-[1]"
/>
</section>

<style>
  @keyframes birdFly1 {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(-12px, -8px);
    }
  }
  @keyframes birdFly2 {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(-8px, -12px);
    }
  }

  @keyframes waveFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 0.8;
    }
  }

  @keyframes sunFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-wave-fade-in {
    animation: waveFadeIn 800ms ease-out both;
  }

  .animate-bird-fly-1 {
    animation: birdFly1 6s ease-in-out infinite;
  }
  .animate-bird-fly-2 {
    animation: birdFly2 5s ease-in-out 1.2s infinite;
  }

  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  .animate-fade-in-left {
    animation: fadeInLeft 900ms ease-out both;
  }
  .animate-fade-in-right {
    animation: fadeInRight 900ms ease-out both;
  }

  .animate-fade-in-left-delayed {
    animation: fadeInLeft 600ms ease-out 1000ms both;
  }
  .animate-fade-in-right-delayed {
    animation: fadeInRight 600ms ease-out 1000ms both;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-up-sun {
    animation: sunFadeUp 700ms ease-out 200ms both;
  }
  .animate-fade-up {
    animation: fadeUp 700ms ease-out 300ms both;
  }

  .soedirman-text {
    color: #001A58;
    -webkit-text-stroke: 3px #DEB65B;
    paint-order: stroke fill;
    font-size: 1.2em;
    display: inline-block;
  }

  .student-summit-text {
    color: #001A58;
    -webkit-text-stroke: 3px #DEB65B;
    paint-order: stroke fill;
    display: inline-block;
  }

  .stylistic-letter {
    font-feature-settings: "ss01" 1, "ss02" 1;
  }

  .year-text {
    color: #001A58;
    -webkit-text-stroke: 3px #DEB65B;
    paint-order: stroke fill;
  }

  .soedirman-hero {
    font-size: 32px;
  }
  @media screen and (min-width: 420px) {
    .soedirman-hero {
      font-size: 36px;
    }
  }
  @media screen and (min-width: 640px) {
    .soedirman-hero {
      font-size: 44px;
    }
  }
  @media screen and (min-width: 768px) {
    .soedirman-hero {
      font-size: 52px;
    }
  }
  @media screen and (min-width: 1024px) {
    .soedirman-hero {
      font-size: 85px;
    }
  }

  .student-summit-hero {
    font-size: 40px;
  }
  @media screen and (min-width: 420px) {
    .student-summit-hero {
      font-size: 44px;
    }
  }
  @media screen and (min-width: 640px) {
    .student-summit-hero {
      font-size: 52px;
    }
  }
  @media screen and (min-width: 768px) {
    .student-summit-hero {
      font-size: 64px;
    }
  }
  @media screen and (min-width: 1024px) {
    .student-summit-hero {
      font-size: 85px;
    }
  }
</style>