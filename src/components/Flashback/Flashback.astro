---
---
<section
  id="flashback"
  class="section-padding-x pt-16 pb-8 text-white-base"
>
    <!-- First Row: Text Left, Video Right -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center justify-center max-w-4xl mx-auto mb-16">
      <div
        data-aos="fade-right"
        data-aos-duration="500"
        data-aos-easing="ease-out"
        data-aos-offset="300"
        data-aos-once="true"
      >
        <h2
          class="font-love-craft text-2xl sm:text-2xl md:text-2xl font-semibold font-heading text-center md:text-right"
        >
          # Release Lagu Gensoed
        </h2>
      </div>
      <div
        data-aos="fade-left"
        data-aos-duration="400"
        data-aos-easing="ease-out"
        data-aos-offset="300"
        data-aos-once="true"
      >
        <iframe
          class="w-full aspect-video rounded-lg shadow-sm shadow-white-base"
          src="https://www.youtube.com/embed/VtGoqmPMe-w?start=31&controls=0"
          title="Video"
          allow="accelerometer; encrypted-media; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        >
        </iframe>
      </div>
    </div>

    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center justify-center max-w-4xl mx-auto">
      <div
        data-aos="fade-right"
        data-aos-duration="400"
        data-aos-easing="ease-out"
        data-aos-offset="300"
        data-aos-once="true"
      >
        <iframe
          class="w-full aspect-video rounded-lg shadow-sm shadow-white-base"
          src="https://www.youtube.com/embed/VtGoqmPMe-w?start=31&controls=0"
          title="Video"
          allow="accelerometer; encrypted-media; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        >
        </iframe>
      </div>
      <div
        data-aos="fade-left"
        data-aos-duration="500"
        data-aos-easing="ease-out"
        data-aos-offset="300"
        data-aos-once="true"
      >
        <h2
          class="font-love-craft text-2xl sm:text-2xl md:text-3xl font-semibold font-heading text-center md:text-right"
        >
          # GenerasiSoedirman
        </h2>
      </div>
    </div>

  </div>
</section>