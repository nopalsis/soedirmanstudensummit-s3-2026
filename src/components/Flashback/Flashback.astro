---
---
<section
  id="flashback"
  class="section-padding-x py-8 sm:py-12 md:py-16 text-white-base"
>
    <div class="flex flex-col gap-8 sm:gap-10 md:gap-12 lg:gap-16 items-center justify-center max-w-6xl mx-auto">
      
      <!-- First Row: Release Lagu Gensoed -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 md:gap-8 items-center justify-center w-full">
        <div
          data-aos="fade-right"
          data-aos-duration="500"
          data-aos-delay="0"
          class="flex items-center justify-center order-1 md:order-1"
        >
          <h2
            class="font-reikna text-2xl xs:text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold drop-shadow-[0_2px_0_rgba(0,40,85,1)] text-center break-words gradient-text-title text-stroke-gold"
          >
            #SalamSoedirman
          </h2>
        </div>
        <iframe
           class="w-full aspect-video rounded-lg shadow-sm shadow-white-base hover:shadow-lg hover:scale-105 transition-all duration-500 ease-out order-2 md:order-2 shadow-blur"
           src="https://www.youtube.com/embed/VtGoqmPMe-w?start=31&controls=0"
           title="Video"
           allow="accelerometer; encrypted-media; web-share"
           referrerpolicy="strict-origin-when-cross-origin"
           allowfullscreen
           data-aos="zoom-in"
           data-aos-duration="600"
           data-aos-delay="500"
         >
         </iframe>
       </div>

       <!-- Second Row: Generasi Soedirman -->
       <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 md:gap-8 items-center justify-center w-full">
         <div
           data-aos="fade-left"
           data-aos-duration="500"
           data-aos-delay="300"
           class="order-1 md:order-2 flex items-center justify-center"
         >
           <h2
             class="font-reikna text-2xl xs:text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold drop-shadow-[0_2px_0_rgba(0,40,85,1)] text-center break-words gradient-text-title text-stroke-gold"
           >
             #GenerasiSoedirman
           </h2>
         </div>
          <iframe
            class="w-full aspect-video rounded-lg shadow-sm shadow-white-base order-2 md:order-1 hover:shadow-lg hover:scale-105 transition-all duration-500 ease-out shadow-blur"
            src="https://www.youtube.com/embed/t35aKfk3TUg?start=5&controls=0"
          >
         </iframe>
       </div>

       <!-- Third Row: Flashmob -->
       <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 md:gap-8 items-center justify-center w-full">
         <div
           data-aos="fade-right"
           data-aos-duration="500"
           data-aos-delay="400"
           class="flex items-center justify-center order-1 md:order-1"
         >
           <h2
             class="font-reikna text-2xl xs:text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold drop-shadow-[0_2px_0_rgba(0,40,85,1)] text-center break-words gradient-text-title text-stroke-gold"
           >
             #Flashmob
           </h2>
         </div>
         <iframe
           class="w-full aspect-video rounded-lg shadow-sm shadow-white-base hover:shadow-lg hover:scale-105 transition-all duration-500 ease-out order-2 md:order-2 shadow-blur"
          src="https://www.youtube.com/embed/VtGoqmPMe-w?start=31&controls=0"
          title="Video"
          allow="accelerometer; encrypted-media; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          data-aos="zoom-in"
          data-aos-duration="600"
          data-aos-delay="500"
        >
        </iframe>
      </div>

    </div>

</section>

<style>
  :global(.scrollbar-hide::-webkit-scrollbar) {
    display: none;
  }

  :global(.shadow-blur) {
    filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.3));
  }
</style>

<section
