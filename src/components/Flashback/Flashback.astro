---
---
<section
  id="flashback"
  class="section-padding-x pt-16 pb-8 text-white-base"
>
    <div class="flex flex-col gap-16 items-center justify-center max-w-6xl mx-auto">
      
      <!-- First Row: Release Lagu Gensoed -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center justify-center w-full">
        <div
          data-aos="fade-right"
          data-aos-duration="500"
          data-aos-delay="0"
          class="flex items-center justify-center"
        >
          <h2
            class="font-junigarden-swash text-3xl sm:text-4xl md:text-5xl font-semibold drop-shadow-[0_2px_0_rgba(0,40,85,1)] text-center whitespace-nowrap gradient-text-title text-stroke-gold"
          >
            #ReleaseLaguGensoed
          </h2>
        </div>
        <iframe
          class="w-full aspect-video rounded-lg shadow-sm shadow-white-base"
          src="https://www.youtube.com/embed/VtGoqmPMe-w?start=31&controls=0"
          title="Video"
          allow="accelerometer; encrypted-media; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          data-aos="zoom-in"
          data-aos-duration="600"
          data-aos-delay="100"
        >
        </iframe>
      </div>

      <!-- Second Row: Generasi Soedirman -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center justify-center w-full">
        <iframe
          class="w-full aspect-video rounded-lg shadow-sm shadow-white-base order-2 md:order-1"
          src="https://www.youtube.com/embed/VtGoqmPMe-w?start=31&controls=0"
          title="Video"
          allow="accelerometer; encrypted-media; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          data-aos="zoom-in"
          data-aos-duration="600"
          data-aos-delay="200"
        >
        </iframe>
        <div
          data-aos="fade-left"
          data-aos-duration="500"
          data-aos-delay="300"
          class="order-1 md:order-2 flex items-center justify-center"
        >
          <h2
            class="font-junigarden-swash text-3xl sm:text-4xl md:text-5xl font-semibold drop-shadow-[0_2px_0_rgba(0,40,85,1)] text-center whitespace-nowrap gradient-text-title text-stroke-gold"
          >
            #GenerasiSoedirman
          </h2>
        </div>
      </div>

      <!-- Third Row: Flashmob -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center justify-center w-full">
        <div
          data-aos="fade-right"
          data-aos-duration="500"
          data-aos-delay="400"
          class="flex items-center justify-center"
        >
          <h2
            class="font-junigarden-swash text-3xl sm:text-4xl md:text-5xl font-semibold drop-shadow-[0_2px_0_rgba(0,40,85,1)] text-center whitespace-nowrap gradient-text-title text-stroke-gold"
          >
            #Flashmob
          </h2>
        </div>
        <iframe
          class="w-full aspect-video rounded-lg shadow-sm shadow-white-base"
          src="https://www.youtube.com/embed/VtGoqmPMe-w?start=31&controls=0"
          title="Video"
          allow="accelerometer; encrypted-media; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          data-aos="zoom-in"
          data-aos-duration="600"
          data-aos-delay="500"
        >
        </iframe>
      </div>

    </div>

  </div>
</section>