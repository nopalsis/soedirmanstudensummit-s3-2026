<script>
  const target = new Date('Aug 1, 2026 08:00:00').getTime();

  function tick() {
    const diff = target - Date.now();
    const d = Math.max(0, Math.floor(diff / 86400000));
    const h = Math.max(0, Math.floor((diff % 86400000) / 3600000));
    const m = Math.max(0, Math.floor((diff % 3600000) / 60000));
    const s = Math.max(0, Math.floor((diff % 60000) / 1000));

    const pad = (n: number) => String(n).padStart(2, '0');

    (document.getElementById('cd-days') as HTMLElement).textContent    = pad(d);
    (document.getElementById('cd-hours') as HTMLElement).textContent   = pad(h);
    (document.getElementById('cd-minutes') as HTMLElement).textContent = pad(m);
    (document.getElementById('cd-seconds') as HTMLElement).textContent = pad(s);
  }

  tick();
  setInterval(tick, 1000);
</script>
