---
import CountdownCard from "./CountdownCard.astro";
import CountdownMap from "./CountdownMap.astro";
---

<section class="w-full py-16 sm:py-24 md:py-32 lg:py-40 px-0 relative">
  <div class="container max-w-screen-xl mx-auto relative z-10 px-4 sm:px-6 md:px-8">
    <div class="flex flex-col items-center justify-center gap-6 sm:gap-8 md:gap-10 lg:gap-12">
      <!-- Scroll Above -->
      <img src="/images/elements/scroll-above.svg" alt="" class="w-24 sm:w-32 md:w-40 lg:w-52" data-aos="fade-down" data-aos-duration="800" data-aos-delay="0" />

      <div class="text-center max-w-full" data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
        <h2 class="gradient-text-title text-stroke-gold font-junigarden-swash text-2xl xs:text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-3 sm:mb-4 leading-tight drop-shadow-lg overflow-x-auto">
          Langkah kecil hari ini, cerita besar menanti!
        </h2>
        <p class="text-xs xs:text-sm sm:text-base md:text-lg lg:text-xl text-white drop-shadow leading-relaxed">
          Ribuan mahasiswa tahun ajaran, bersiaplah menyambut pengalaman luar biasa di Soedirman Student Summit 2026
        </p>
      </div>

      <div data-aos="zoom-in" data-aos-duration="800" data-aos-delay="200">
        <CountdownCard />
      </div>
      <div data-aos="fade-up" data-aos-duration="800" data-aos-delay="300">
        <CountdownMap />
      </div>

      <!-- Scroll Down -->
      <img src="/images/elements/scroll-down.svg" alt="" class="w-24 sm:w-32 md:w-40 lg:w-52" data-aos="fade-down" data-aos-duration="800" data-aos-delay="400" />
    </div>
    
  </div>
</section>
