---
import NavLink from './NavLink.astro';
---

<header
  id="header"
  class="w-full fixed top-0 left-0 z-999 transition-all duration-300 bg-s3-blue/50 backdrop-blur-md border-b border-white/10"
>
  <nav class="max-w-7xl mx-auto px-6 flex items-center justify-between py-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform bg-s3-gold">
        <span class="font-space-grotesk font-black text-lg text-s3-blue">S3</span>
      </div>
      <span class="hidden md:block font-space-grotesk font-bold text-lg text-white tracking-tight">
        Soedirman Student Summit
      </span>
    </a>

    <!-- Desktop Nav Links (center) -->
    <div class="hidden md:flex items-center gap-8 font-plus-jakarta-sans font-semibold text-sm uppercase tracking-wider">
      <NavLink href="/">Beranda</NavLink>
      <NavLink href="/tentang-unsoed">Tentang S3</NavLink>
      <NavLink href="/info-gensoed">Panduan</NavLink>
    </div>

    <!-- CTA -->
    <a
      href="/hubungi-kami"
      class="hidden md:block font-plus-jakarta-sans font-bold text-sm px-5 py-2 rounded-full transition-all hover:-translate-y-0.5 hover:bg-white bg-s3-gold text-s3-blue"
    >
      Kontak
    </a>

    <!-- Mobile hamburger -->
    <button id="mobileMenuBtn" class="md:hidden p-2 text-white" aria-label="Toggle Menu">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobileSidebar"
    class="md:hidden overflow-hidden max-h-0 opacity-0 transition-all duration-300 bg-s3-deep-blue/97"
  >
    <div class="flex flex-col gap-4 px-6 py-5">
      <NavLink href="/">Beranda</NavLink>
      <NavLink href="/tentang-unsoed">Tentang S3</NavLink>
      <NavLink href="/info-gensoed">Panduan</NavLink>
      <NavLink href="/hubungi-kami">Kontak</NavLink>
    </div>
  </div>
</header>

<script>
  // Mobile toggle
  const btn = document.getElementById('mobileMenuBtn');
  const sidebar = document.getElementById('mobileSidebar');
  btn?.addEventListener('click', () => {
    const open = sidebar?.classList.contains('max-h-screen');
    if (open) {
      sidebar?.classList.remove('max-h-screen', 'opacity-100');
      sidebar?.classList.add('max-h-0', 'opacity-0');
    } else {
      sidebar?.classList.remove('max-h-0', 'opacity-0');
      sidebar?.classList.add('max-h-screen', 'opacity-100');
    }
  });

  // Scroll effect
  window.addEventListener('scroll', () => {
    const header = document.getElementById('header');
    if (!header) return;
    if (window.scrollY > 50) {
      header.classList.remove('bg-s3-blue/50');
      header.classList.add('bg-s3-deep-blue/90');
    } else {
      header.classList.remove('bg-s3-deep-blue/90');
      header.classList.add('bg-s3-blue/50');
    }
  });
</script>
